---
/**
 * DocsSearch — inline dropdown search matching src/components/GlobalSearch.tsx
 * on the marketing site:
 *
 *   - Real <input> styled as the search box
 *   - On focus / click: dropdown panel anchored to the input shows
 *     SNARVEIER + POPULÆRE SØK chip groups
 *   - On typing: live results via Pagefind (loaded lazily) — UNCHANGED,
 *     low-latency keyword typeahead. Never calls the federated endpoint,
 *     so there is zero added latency on the keyword path.
 *   - "Spør AI" / Enter: federated AI-RAG via the Convex
 *     /api/federated-search endpoint (server-side synthesis). Renders
 *     origin-grouped results — Dokumentasjon (primary) + Lokaler / På
 *     digilist.no (secondary) — with a Norwegian (bokmål) answer +
 *     citations. Replaces the previous /api/docs-ask path (which used the
 *     docs deployment's own Anthropic key; synthesis is now server-side).
 *   - Keyboard: ↑/↓ navigate, ↵ select, esc close
 *   - Click outside: close
 *
 * Hand-off: when the user picks a popular-search chip we open the
 * existing Pagefind dialog pre-populated with the query so the actual
 * search corpus + UI stays Starlight-native. The dropdown is just the
 * empty-state and quick-pick surface.
 *
 * Graceful degradation (hard requirement): the federated call is wrapped
 * in a timeout + try/catch. If the endpoint is unreachable / slow /
 * errors, we fall back to the existing Pagefind docs results so the UI
 * is never broken and no unhandled rejection reaches the user.
 *
 * Config (build-time env, see apps/docs/.env.example):
 *   PUBLIC_FEDERATED_SEARCH_URL — Convex federated-search host. Defaults
 *     to the DEV host; flip to https://convex.digilist.no/... for prod.
 *   PUBLIC_LISTINGS_BASE_URL    — base host for Lokaler deep links
 *     (default https://app.digilist.no → /listing/<slug>).
 *   PUBLIC_FEDERATED_TIMEOUT_MS — abort + Pagefind-fallback deadline for
 *     the AI path. Default 12000ms: server-side rerank + LLM synthesis
 *     measured at ~6–9s against dev, so the brief's ~3–4s suggestion
 *     would abort every real answer. Tunable without a code change.
 */
const FEDERATED_SEARCH_URL =
  import.meta.env.PUBLIC_FEDERATED_SEARCH_URL ??
  "https://convex.dev.digilist.no/api/federated-search";
const LISTINGS_BASE_URL =
  import.meta.env.PUBLIC_LISTINGS_BASE_URL ?? "https://app.digilist.no";
const FEDERATED_TIMEOUT_MS =
  import.meta.env.PUBLIC_FEDERATED_TIMEOUT_MS ?? "12000";
---

<div
  class="dg-search"
  data-dg-search
  data-federated-url={FEDERATED_SEARCH_URL}
  data-listings-base={LISTINGS_BASE_URL}
  data-federated-timeout={FEDERATED_TIMEOUT_MS}
>
  <div class="dg-search__inputwrap">
    <svg class="dg-search__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="11" cy="11" r="8"></circle>
      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    </svg>
    <input
      class="dg-search__input"
      type="search"
      placeholder="Spør AI, eller søk i Digilist…"
      aria-label="Spør AI eller søk i dokumentasjonen"
      autocomplete="off"
      spellcheck="false"
      data-dg-search-input
    />
    <button
      type="button"
      class="dg-search__ask"
      data-dg-ask
      aria-label="Spør AI om dette"
      title="Spør AI (Enter)"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 2 14.5 8.5 21 11 14.5 13.5 12 20 9.5 13.5 3 11 9.5 8.5Z"/>
      </svg>
      Spør AI
    </button>
    <kbd class="dg-search__kbd" aria-hidden="true">⌘ K</kbd>
  </div>

  <div class="dg-search__panel" data-dg-search-panel hidden>
    <!-- Empty-state chip groups -->
    <div class="dg-search__empty" data-dg-search-empty>
      <section class="dg-search__group">
        <p class="dg-search__heading">SNARVEIER</p>
        <ul class="dg-search__chips">
          <li><a href="/kom-i-gang/" class="dg-search__chip" data-dg-chip>Kom i gang</a></li>
          <li><a href="/admin/" class="dg-search__chip" data-dg-chip>Admin-runbooks</a></li>
          <li><a href="/api-referanse/" class="dg-search__chip" data-dg-chip>API-referanse</a></li>
          <li><a href="/compliance/" class="dg-search__chip" data-dg-chip>Compliance</a></li>
        </ul>
      </section>
      <section class="dg-search__group">
        <p class="dg-search__heading">POPULÆRE SØK</p>
        <ul class="dg-search__chips">
          <li><button type="button" class="dg-search__chip" data-dg-query="sesongleie">Sesongleie</button></li>
          <li><button type="button" class="dg-search__chip" data-dg-query="vipps">Vipps</button></li>
          <li><button type="button" class="dg-search__chip" data-dg-query="SSA-L 2026">SSA-L 2026</button></li>
          <li><button type="button" class="dg-search__chip" data-dg-query="BankID">BankID</button></li>
          <li><button type="button" class="dg-search__chip" data-dg-query="EHF">EHF</button></li>
          <li><button type="button" class="dg-search__chip" data-dg-query="ID-porten">ID-porten</button></li>
          <li><button type="button" class="dg-search__chip" data-dg-query="kommune">Kommune</button></li>
          <li><button type="button" class="dg-search__chip" data-dg-query="vekst harness">Vekst-harness</button></li>
        </ul>
      </section>
      <footer class="dg-search__footer">
        <span><kbd>↓</kbd> bla</span>
        <span><kbd>↵</kbd> velg</span>
        <span><kbd>esc</kbd> lukk</span>
      </footer>
    </div>

    <!-- AI answer pane (Claude RAG over docs corpus). -->
    <div class="dg-search__ai" data-dg-search-ai hidden></div>

    <!-- Live results (Pagefind handoff). -->
    <div class="dg-search__results" data-dg-search-results hidden></div>
  </div>
</div>

<script is:inline>
  (function(){
    const root = document.querySelector('[data-dg-search]');
    if (!root) return;
    const input = root.querySelector('[data-dg-search-input]');
    const panel = root.querySelector('[data-dg-search-panel]');
    const emptyEl = root.querySelector('[data-dg-search-empty]');
    const resultsEl = root.querySelector('[data-dg-search-results]');

    function open() {
      panel.hidden = false;
      root.classList.add('dg-search--open');
    }
    function close() {
      panel.hidden = true;
      root.classList.remove('dg-search--open');
    }

    input.addEventListener('focus', open);
    input.addEventListener('click', open);

    // Click outside closes the panel.
    document.addEventListener('click', (e) => {
      if (!root.contains(e.target)) close();
    });

    // ⌘K / Ctrl+K focuses the input (matches Pagefind default).
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        input.focus();
        input.select();
      }
      if (e.key === 'Escape' && root.classList.contains('dg-search--open')) {
        close();
        input.blur();
      }
    });

    // Chip clicks — popular-search chips run a live search via Pagefind.
    // Snarvei chips are plain <a> links → browser handles navigation.
    root.querySelectorAll('[data-dg-query]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const q = btn.getAttribute('data-dg-query') || '';
        input.value = q;
        runSearch(q);
      });
    });

    let pagefindReady = null;
    async function ensurePagefind() {
      if (pagefindReady) return pagefindReady;
      pagefindReady = (async () => {
        // Pagefind ships JS + WASM at /pagefind/ when Starlight builds.
        // Note: the docs nginx vhost CSP must include 'wasm-unsafe-eval'.
        try {
          const mod = await import('/pagefind/pagefind.js');
          if (typeof mod.init === 'function') {
            await mod.init();
          }
          return mod;
        } catch (e) {
          console.warn('[docs-search] Pagefind unavailable', e);
          return null;
        }
      })();
      return pagefindReady;
    }

    async function runSearch(query) {
      open();
      if (!query.trim()) {
        emptyEl.hidden = false;
        resultsEl.hidden = true;
        resultsEl.innerHTML = '';
        return;
      }
      emptyEl.hidden = true;
      resultsEl.hidden = false;
      resultsEl.innerHTML = '<p class="dg-search__loading">Søker …</p>';
      const pf = await ensurePagefind();
      if (!pf) {
        resultsEl.innerHTML = '<p class="dg-search__empty-msg">Søk er ikke tilgjengelig akkurat nå.</p>';
        return;
      }
      try {
        const search = await pf.search(query);
        const items = await Promise.all(search.results.slice(0, 6).map((r) => r.data()));
        if (items.length === 0) {
          resultsEl.innerHTML = '<p class="dg-search__empty-msg">Ingen treff for «' + escape(query) + '».</p>';
          return;
        }
        resultsEl.innerHTML = items.map((it) => {
          const title = it.meta?.title || it.url;
          const url = it.url;
          const excerpt = it.excerpt || '';
          return '<a class="dg-search__result" href="' + url + '">'
               +   '<span class="dg-search__result-title">' + escape(title) + '</span>'
               +   '<span class="dg-search__result-excerpt">' + excerpt + '</span>'
               + '</a>';
        }).join('');
      } catch (e) {
        console.warn('[docs-search] search failed', e);
        resultsEl.innerHTML = '<p class="dg-search__empty-msg">Kunne ikke søke akkurat nå.</p>';
      }
    }

    function escape(s) {
      return String(s).replace(/[&<>"']/g, (c) => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#x27;'}[c]));
    }

    let timer;
    input.addEventListener('input', () => {
      clearTimeout(timer);
      timer = setTimeout(() => runSearch(input.value), 140);
    });

    // ── Federated AI ask (Convex /api/federated-search) ─────────
    // Replaces the old /api/docs-ask path: server-side synthesis, no
    // docs-local Anthropic key, origin-grouped results. The keyword
    // typeahead above (runSearch / Pagefind) is untouched.
    const askBtn = root.querySelector('[data-dg-ask]');
    const aiEl = root.querySelector('[data-dg-search-ai]');
    const FEDERATED_URL = root.getAttribute('data-federated-url') || '';
    const LISTINGS_BASE = (root.getAttribute('data-listings-base') || 'https://app.digilist.no').replace(/\/+$/, '');
    // Server-side rerank + LLM synthesis measured at ~6–9s; default 12s so
    // real answers render, while still bounding a genuinely hung endpoint.
    const ASK_TIMEOUT_MS = parseInt(root.getAttribute('data-federated-timeout') || '12000', 10) || 12000;

    // Map federated origin → UI group. Documentation is primary (first,
    // emphasised); Lokaler + På digilist.no are secondary.
    const GROUPS = [
      { key: 'docs', label: 'Dokumentasjon', primary: true },
      { key: 'listing', label: 'Lokaler', primary: false },
      { key: 'marketing', label: 'På digilist.no', primary: false },
    ];

    function aiHead(q) {
      return '<div class="dg-search__ai-head">' +
          '<span class="dg-search__ai-badge">SPØR AI</span>' +
          '<span class="dg-search__ai-q">' + escape(q) + '</span>' +
        '</div>';
    }

    // Deep link for a Lokaler result: prefer app.digilist.no/listing/<slug>
    // (slug from raw.slug, else parsed off the server-built url); fall back
    // to the absolute url the endpoint returned.
    function listingHref(item) {
      var slug = item && item.raw && item.raw.slug;
      if (!slug && item && item.url) {
        var m = String(item.url).match(/\/listing\/([^/?#]+)/);
        if (m) slug = m[1];
      }
      if (slug) return LISTINGS_BASE + '/listing/' + slug;
      return (item && item.url) || '#';
    }

    function resultHref(group, item) {
      if (group.key === 'listing') return listingHref(item);
      return (item && item.url) || '#';
    }

    function renderGroup(group, items) {
      if (!items || !items.length) return '';
      var rows = items.map(function (it) {
        var title = it.title || it.url || '';
        var excerpt = it.excerpt || '';
        return '<a class="dg-search__result" href="' + resultHref(group, it) + '">' +
            '<span class="dg-search__result-title">' + escape(title) + '</span>' +
            (excerpt ? '<span class="dg-search__result-excerpt">' + escape(excerpt) + '</span>' : '') +
          '</a>';
      }).join('');
      return '<section class="dg-search__ai-group' + (group.primary ? ' dg-search__ai-group--primary' : '') + '">' +
          '<p class="dg-search__heading">' + escape(group.label) + '</p>' +
          '<div class="dg-search__results">' + rows + '</div>' +
        '</section>';
    }

    function renderFederated(q, data) {
      var html = aiHead(q);
      var chat = data && data.chat;
      // Contract carries the answer as chat.text (current) — also accept
      // chat.answer for forward/backward compatibility.
      var answer = chat && (chat.text || chat.answer);
      if (answer) {
        html += '<div class="dg-search__ai-body">' + renderMd(answer) + '</div>';
        var cites = (chat && chat.citations) || [];
        if (cites.length) {
          html += '<div class="dg-search__ai-cites">' +
            '<p class="dg-search__ai-cites-head">KILDER</p><ul>' +
              cites.map(function (c) {
                var href = c.url || c.href || '#';
                var label = c.title || c.page_title || href;
                return '<li><a href="' + href + '">' + escape(label) + ' <span aria-hidden="true">→</span></a></li>';
              }).join('') +
            '</ul></div>';
        }
      }
      var groups = (data && data.groups) || {};
      var grouped = GROUPS.map(function (g) { return renderGroup(g, groups[g.key]); }).join('');
      if (grouped) {
        html += '<div class="dg-search__ai-groups">' + grouped + '</div>';
      }
      if (!answer && !grouped) {
        html += '<p class="dg-search__empty-msg">Ingen treff for «' + escape(q) + '».</p>';
      }
      aiEl.innerHTML = html;
    }

    async function ask(query) {
      const q = (query || input.value).trim();
      if (!q) {
        input.focus();
        return;
      }
      open();
      emptyEl.hidden = true;
      resultsEl.hidden = true;
      aiEl.hidden = false;
      aiEl.innerHTML = aiHead(q) + '<p class="dg-search__loading">Tenker …</p>';

      if (!FEDERATED_URL) { await askFallback(q); return; }

      // Timeout so a slow/hung endpoint degrades to Pagefind instead of
      // spinning forever.
      const controller = new AbortController();
      const timeout = setTimeout(function () { controller.abort(); }, ASK_TIMEOUT_MS);
      try {
        const r = await fetch(FEDERATED_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ query: q, useRerank: true, useChat: true }),
          signal: controller.signal,
        });
        clearTimeout(timeout);
        if (!r.ok) throw new Error('federated-search HTTP ' + r.status);
        const data = await r.json();
        renderFederated(q, data);
      } catch (e) {
        clearTimeout(timeout);
        console.warn('[docs-search] federated AI unavailable — falling back to Pagefind', e);
        await askFallback(q);
      }
    }

    // Graceful fallback: render existing Pagefind docs results so the
    // user always gets something useful, never a broken AI pane.
    async function askFallback(q) {
      aiEl.hidden = true;
      aiEl.innerHTML = '';
      input.value = q;
      await runSearch(q);
    }

    // Minimal markdown renderer — handles bold, italic, links, lists, paragraphs.
    function renderMd(s) {
      var lines = s.split(/\r?\n/);
      var out = [];
      var inList = false;
      for (var i = 0; i < lines.length; i++) {
        var line = lines[i];
        var li = line.match(/^\s*[-*]\s+(.*)$/);
        if (li) {
          if (!inList) { out.push('<ul>'); inList = true; }
          out.push('<li>' + inlineMd(li[1]) + '</li>');
          continue;
        }
        if (inList) { out.push('</ul>'); inList = false; }
        if (!line.trim()) { out.push(''); continue; }
        out.push('<p>' + inlineMd(line) + '</p>');
      }
      if (inList) out.push('</ul>');
      return out.join('\n');
    }
    function inlineMd(s) {
      return escape(s)
        .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
        .replace(/\*([^*]+)\*/g, '<em>$1</em>')
        .replace(/`([^`]+)`/g, '<code>$1</code>')
        .replace(/\[([^\]]+)\]\((\/[^\s)]+)\)/g,
          '<a href="$2">$1</a>');
    }

    if (askBtn) askBtn.addEventListener('click', () => ask());

    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        ask();
      }
    });

    window.dgSearchHandleAsk = ask;
  })();
</script>

<style is:global>
  /* Global scope so dynamic innerHTML (Pagefind result rows + AI answer
   * markdown) gets styled. Astro's default scoped CSS only applies to
   * tags rendered at component-build time. */
  .dg-search {
    position: relative;
    width: 100%;
    max-width: 35rem;          /* +10% over the previous 32rem cap */
    margin-inline: auto;
  }

  .dg-search__inputwrap {
    position: relative;
    display: flex;
    align-items: center;
    height: 3rem;
    padding-inline: 1rem 0.6rem;
    background: hsl(var(--paper-deep));
    border: 0.5px solid hsl(var(--rule-strong));
    border-radius: 8px;
    transition:
      border-color 160ms var(--ease-editorial),
      background 160ms var(--ease-editorial),
      box-shadow 160ms var(--ease-editorial);
  }

  .dg-search--open .dg-search__inputwrap,
  .dg-search__inputwrap:focus-within {
    border-color: hsl(var(--accent-text));
    background: hsl(var(--paper));
    box-shadow: 0 0 0 4px hsl(var(--accent-tinted));
  }

  .dg-search__icon {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    color: hsl(var(--accent-text));
    margin-inline-end: 0.6rem;
  }

  .dg-search__input {
    flex: 1;
    height: 100%;
    background: transparent;
    border: 0;
    outline: 0 !important;
    box-shadow: none !important;
    font-family: "Public Sans", system-ui, sans-serif;
    font-size: 1rem;
    color: hsl(var(--ink));
  }

  /* The wrap is the focus indicator, not the input — kill any browser
   * default ring/highlight on the input itself. */
  .dg-search__input:focus,
  .dg-search__input:focus-visible {
    outline: 0 !important;
    box-shadow: none !important;
  }

  .dg-search__input::placeholder {
    color: hsl(var(--ink-faint));
  }

  /* Remove the native clear button on type=search */
  .dg-search__input::-webkit-search-cancel-button {
    -webkit-appearance: none;
    appearance: none;
  }

  .dg-search__kbd {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.72rem;
    background: hsl(var(--paper));
    border: 0.5px solid hsl(var(--rule-strong));
    border-radius: 4px;
    padding: 0.25rem 0.5rem;
    color: hsl(var(--ink-soft));
    flex-shrink: 0;
    line-height: 1;
    letter-spacing: 0.04em;
  }

  /* ── Dropdown panel ──────────────────────────────────────── */
  .dg-search__panel {
    position: absolute;
    top: calc(100% + 0.5rem);
    inset-inline: 0;
    padding: 1.25rem;
    background: hsl(var(--paper));
    border: 0.5px solid hsl(var(--rule-strong));
    border-radius: 10px;
    box-shadow: 0 24px 60px -28px hsla(var(--navy) / 0.28);
    z-index: 60;
  }

  .dg-search__group + .dg-search__group {
    margin-block-start: 1rem;
  }

  .dg-search__heading {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.62rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: hsl(var(--accent-text));
    font-weight: 600;
    margin: 0 0 0.65rem;
  }

  .dg-search__chips {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .dg-search__chip {
    display: inline-flex;
    align-items: center;
    font-family: "Public Sans", system-ui, sans-serif;
    font-size: 0.875rem;
    line-height: 1.2;
    color: hsl(var(--ink));
    background: hsl(var(--paper));
    border: 0.5px solid hsl(var(--rule-strong));
    border-radius: 999px;
    padding: 0.45rem 0.9rem;
    text-decoration: none;
    cursor: pointer;
    transition:
      background 140ms var(--ease-editorial),
      color 140ms var(--ease-editorial),
      border-color 140ms var(--ease-editorial),
      transform 140ms var(--ease-editorial);
  }

  .dg-search__chip:hover,
  .dg-search__chip:focus-visible {
    background: hsl(var(--accent-tinted));
    color: hsl(var(--accent-text));
    border-color: hsl(var(--accent-text));
    outline: 0;
  }

  .dg-search__chip:active { transform: scale(0.97); }

  .dg-search__footer {
    margin-block-start: 1rem;
    padding-block-start: 0.85rem;
    border-block-start: 0.5px solid hsl(var(--rule));
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: hsl(var(--ink-faint));
  }

  .dg-search__footer kbd {
    font-family: inherit;
    font-size: inherit;
    background: hsl(var(--paper-deep));
    border: 0.5px solid hsl(var(--rule));
    border-radius: 3px;
    padding: 0.1rem 0.35rem;
    margin-inline-end: 0.4rem;
    color: hsl(var(--ink));
  }

  /* ── Live results ────────────────────────────────────────── */
  .dg-search__loading,
  .dg-search__empty-msg {
    font-family: "Public Sans", system-ui, sans-serif;
    font-size: 0.9rem;
    color: hsl(var(--ink-soft));
    padding: 0.5rem 0;
    margin: 0;
  }

  .dg-search__results {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .dg-search__result {
    display: block;
    padding: 0.75rem 0.85rem;
    border-radius: 6px;
    border: 0.5px solid transparent;
    text-decoration: none;
    color: inherit;
    transition:
      background 120ms var(--ease-editorial),
      border-color 120ms var(--ease-editorial);
  }

  .dg-search__result + .dg-search__result {
    border-block-start: 0.5px solid hsl(var(--rule));
    border-radius: 0;
  }

  .dg-search__result:hover,
  .dg-search__result:focus-visible {
    background: hsl(var(--accent-tinted));
    border-color: hsl(var(--accent-text));
    outline: 0;
  }

  .dg-search__result-title {
