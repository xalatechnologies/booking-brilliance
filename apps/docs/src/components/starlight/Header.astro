---
/**
 * Editorial header — mirrors src/components/Navbar.tsx of the marketing
 * site exactly. The logo + wordmark block is identical:
 *   - public/logo.svg (raster-in-SVG mark) at 44–48px
 *   - "Digilist" in Fraunces opsz 96 / wght 460 / SOFT 25 / WONK 1
 *   - "Enkel booking" italic subhead with hairline accent
 *
 * Replaces the default Starlight title with our own anchor so we don't
 * inherit the stock SiteTitle treatment.
 */
import type { Props } from "@astrojs/starlight/props";
import DocsSearch from "./DocsSearch.astro";
import ThemeToggle from "./ThemeToggle.astro";
---

<div class="dg-header">
  <div class="dg-header__inner">
    <a href="/" class="dg-header__brand" aria-label="Digilist — gå til forsiden">
      <img
        src="/logo-64.webp"
        alt=""
        aria-hidden="true"
        class="dg-header__logo"
        width="44"
        height="44"
      />
      <span class="dg-header__wordmark">
        <span class="dg-header__wordmark-name">Digilist</span>
        <span class="dg-header__wordmark-sub">
          <span class="dg-header__wordmark-tick" aria-hidden="true"></span>
          <span class="dg-header__wordmark-tag">Dokumentasjon</span>
          <span class="dg-header__wordmark-dot" aria-hidden="true"></span>
        </span>
      </span>
    </a>

    <div class="dg-header__search">
      <DocsSearch />
    </div>

    <script is:inline>
      // Norwegianize Starlight's built-in English labels left elsewhere.
      (function(){
        var SWAPS = [
          { sel: 'a', match: /^\s*Edit page\s*$/i, to: 'Rediger side' },
          { sel: 'p, span', textIncludes: 'Last updated:',
            replace: ['Last updated:', 'Sist oppdatert:'] },
          { sel: 'a', match: /^\s*Skip to content\s*$/i, to: 'Hopp til innhold' },
          { sel: '.right-sidebar h2', match: /^\s*On this page\s*$/i, to: 'På denne siden' },
          { sel: '.right-sidebar a, .right-sidebar li',
            match: /^\s*Overview\s*$/i, to: 'Oversikt' },
        ];
        function walk() {
          SWAPS.forEach(function(s){
            document.querySelectorAll(s.sel).forEach(function(el){
              var t = el.textContent;
              if (!t) return;
              if (s.match && s.match.test(t.trim())) {
                el.textContent = s.to;
              } else if (s.textIncludes && t.indexOf(s.textIncludes) !== -1 && s.replace) {
                el.textContent = t.replace(s.replace[0], s.replace[1]);
              }
            });
          });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', walk, { once: true });
        } else { walk(); }
        new MutationObserver(walk).observe(document.body, { childList: true, subtree: true });
      })();
    </script>

    <div class="dg-header__actions">
      <nav class="dg-header__links" aria-label="Eksternt">
        <a href="https://digilist.no/" class="dg-header__btn dg-header__btn--ghost">
          Hjemmeside <span aria-hidden="true">↗</span>
        </a>
        <a href="https://app.digilist.no/" class="dg-header__btn dg-header__btn--ghost">
          Plattform <span aria-hidden="true">↗</span>
        </a>
      </nav>
      <ThemeToggle />
      <a class="dg-header__cta" href="https://digilist.no/book-demo">
        Book demo <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</div>

<style>
  .dg-header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: hsl(var(--paper));
    border-bottom: 1px solid hsl(var(--rule));
    backdrop-filter: blur(8px);
  }

  .dg-header__inner {
    /* Header padding follows --dg-gutter so its left/right edges align
     * with the sidebar + content below. brand · search · actions. */
    max-width: none;
    margin: 0 auto;
    padding-block: 0;
    padding-inline: var(--dg-gutter, 1.5rem);
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 1.25rem;
    align-items: center;
    min-height: 4.5rem;
  }

  @media (min-width: 64em) {
    .dg-header__inner { gap: 2rem; }
  }

  .dg-header__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    text-decoration: none;
    color: inherit;
  }

  .dg-header__logo {
    height: 2.75rem;
    width: 2.75rem;
    object-fit: contain;
    transition: opacity 120ms ease;
  }

  @media (min-width: 48em) {
    .dg-header__logo { height: 3rem; width: 3rem; }
  }

  .dg-header__brand:hover .dg-header__logo { opacity: 0.8; }

  .dg-header__wordmark {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    line-height: 1;
  }

  .dg-header__wordmark-name {
    font-family: "Fraunces", "Iowan Old Style", Georgia, serif;
    /* opsz 96 / wght 460 / SOFT 25 / WONK 1 — copied 1:1 from
     * src/components/Navbar.tsx so the wordmark renders identically. */
    font-variation-settings: "opsz" 96, "wght" 460, "SOFT" 25, "WONK" 1;
    font-size: 1.85rem;
    color: hsl(var(--ink));
    letter-spacing: -0.02em;
    line-height: 1;
  }

  @media (min-width: 48em) {
    .dg-header__wordmark-name { font-size: 2rem; }
  }

  .dg-header__wordmark-sub {
    margin-top: 0.15rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .dg-header__wordmark-tick {
    display: inline-block;
    width: 0.875rem;
    height: 1px;
    background: hsl(var(--accent-text));
  }

  .dg-header__wordmark-tag {
    font-family: "Fraunces", "Iowan Old Style", Georgia, serif;
    font-style: italic;
    font-variation-settings: "opsz" 16, "wght" 420, "SOFT" 60, "WONK" 0;
    font-size: 0.9rem;
    color: hsl(var(--ink-soft));
    letter-spacing: 0.005em;
    line-height: 1;
  }

  .dg-header__wordmark-dot {
    display: inline-block;
    width: 0.25rem;
    height: 0.25rem;
    border-radius: 9999px;
    background: hsl(var(--accent-text));
    opacity: 0.6;
  }

  /* Search wrapper — centered in the middle column. The DocsSearch
   * component caps itself at 35rem; this wrap just lets it grow. */
  .dg-header__search {
    justify-self: center;
    width: 100%;
    max-width: 35rem;
    display: flex;
    align-items: center;
  }

  .dg-header__search > :global(site-search) {
    width: 100%;
    display: block;
  }

  .dg-header__actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .dg-header__links {
    display: none;
    align-items: center;
    gap: 0.5rem;
    padding-inline-end: 0.5rem;
    margin-inline-end: 0.25rem;
    border-inline-end: 0.5px solid hsl(var(--rule-strong));
  }

  @media (min-width: 64em) {
    .dg-header__links { display: inline-flex; }
  }

  /* Header buttons — proper buttons, hairline-bordered, mirrors the
   * marketing EditorialButton "ghost" variant. WCAG 44px tall. */
  .dg-header__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    min-height: 2.75rem;
    padding: 0 1rem;
    font-family: "Public Sans", system-ui, sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1;
    color: hsl(var(--ink));
    background: transparent;
    border: 0.5px solid hsl(var(--rule-strong));
    border-radius: 6px;
    text-decoration: none;
    white-space: nowrap;
    transition:
      color 160ms var(--ease-editorial),
      background 160ms var(--ease-editorial),
      border-color 160ms var(--ease-editorial);
  }

  .dg-header__btn:hover {
    color: hsl(var(--accent-text));
    background: hsl(var(--accent-tinted));
    border-color: hsl(var(--accent-text));
  }

  .dg-header__btn span {
    font-size: 0.75rem;
    color: hsl(var(--accent-text));
  }

  .dg-header__cta {
    display: none;
    white-space: nowrap;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.65rem 1.1rem;
    background: hsl(var(--navy));
    color: hsl(var(--on-navy));
    border: 1px solid hsl(var(--navy));
    border-radius: 2px;
    transition: background 120ms ease, color 120ms ease;
    line-height: 1;
  }

  .dg-header__cta:hover {
    background: hsl(var(--paper));
    color: hsl(var(--navy));
  }

  @media (min-width: 56em) {
    .dg-header__cta { display: inline-flex; align-items: center; gap: 0.35rem; }
  }
</style>
