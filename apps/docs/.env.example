# Digilist Docs (Starlight) — build-time configuration.
# Copy to .env.local (or set in CI) and adjust per environment.
# Only PUBLIC_* vars are exposed to the client bundle.

# Convex federated AI-RAG endpoint backing the "Spør AI" path in
# DocsSearch.astro. Build/verify against DEV; flip to prod only once the
# prod host is confirmed live (see FUL-19 / FUL-12).
#   dev:  https://convex.dev.digilist.no/api/federated-search   (default)
#   prod: https://convex.digilist.no/api/federated-search
PUBLIC_FEDERATED_SEARCH_URL="https://convex.dev.digilist.no/api/federated-search"

# Base host for "Lokaler" (listing) deep links: <base>/listing/<slug>.
# Defaults to the customer app; falls back to digilist.no at the hosting
# layer if app.digilist.no is unavailable.
PUBLIC_LISTINGS_BASE_URL="https://app.digilist.no"

# Abort + Pagefind-fallback deadline (ms) for the AI path. Server-side
# rerank + LLM synthesis measured at ~6–9s against dev, so the brief's
# ~3–4s suggestion would abort every real answer. 12s default leaves
# headroom while still bounding a hung endpoint.
PUBLIC_FEDERATED_TIMEOUT_MS="12000"
