# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
dist-server
*.tsbuildinfo
*.local

# Local secrets — never commit. Production uses /etc/digilist-api.env on VPS.
server/.env
tools/content-agent/reports/
tools/site-intelligence/reports/

# Convex deployment id — generated by `npx convex dev`. The committed
# convex/_generated/ stubs are placeholders; the real generated files
# get checked in once convex dev has been run at least once.
.convex/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Improvements-agent local operational brain (machine-specific). This is also
# the knowledge layer's store: its raw `signals` inbox and distilled `knowledge`
# live in brain.json, distilled from the PRIVATE Digilist repo's internals.
tools/improvements-agent/brain/

# Fleet knowledge wiki — distilled from the private Digilist repo, so it must
# NEVER be committed to THIS public repo. The knowledge agent renders + publishes
# it to a dedicated branch in the private Digilist repo instead (see
# tools/knowledge-agent/vps-knowledge-runner.sh). Ignored here as a hard guard
# in case a render ever targets this tree by default.
/KNOWLEDGE.md
/docs/knowledge/

# PR-review-agent local state (machine-specific)
tools/pr-review-agent/state/

# E2E agent artifacts
tools/e2e-agent/report.json
tools/e2e-agent/test-results/
tools/e2e-agent/playwright-report/

tools/e2e-agent/auth/.auth/
