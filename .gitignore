# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
dist-server
*.tsbuildinfo
*.local

# Local secrets — never commit. Production uses /etc/digilist-api.env on VPS.
server/.env
tools/content-agent/reports/
tools/site-intelligence/reports/

# Convex deployment id — generated by `npx convex dev`. The committed
# convex/_generated/ stubs are placeholders; the real generated files
# get checked in once convex dev has been run at least once.
.convex/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Agent fleet — knowledge store (brain/state local; content-memory tracked)
.xala-agents/brain/
.xala-agents/pr-review/

# Legacy agent state (superseded by .xala-agents/)
tools/improvements-agent/brain/
tools/pr-review-agent/state/

# E2E agent artifacts
tools/e2e-agent/report.json
tools/e2e-agent/test-results/
tools/e2e-agent/playwright-report/

tools/e2e-agent/auth/.auth/
.xaheen/
test-results/
# Root-level agent runtime dir only — anchored so it does NOT also ignore
# src/content/blog (the daily blog agent's committed posts → the deploy source).
/content/
apps/docs/public/demos/
