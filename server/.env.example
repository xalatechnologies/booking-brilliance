# /etc/digilist-api.env  (chmod 600, owned by root)
#
# Required for the Digilist chatbot backend on digilist.no
# Copy to /etc/digilist-api.env on the VPS, fill in real values,
# then `systemctl restart digilist-api` (or `pm2 restart digilist-api`).

# Anthropic Claude API key — required for /api/chat
ANTHROPIC_API_KEY=

# Resend API key — required for /api/inquiry
RESEND_API_KEY=

# Email routing
NOTIFY_TO=admin@digilist.no
NOTIFY_CC=info@xala.no,hamid@xala.no
MAIL_FROM=Digilist <onboarding@resend.dev>

# Service config
PORT=3001
ALLOWED_ORIGIN=https://digilist.no
